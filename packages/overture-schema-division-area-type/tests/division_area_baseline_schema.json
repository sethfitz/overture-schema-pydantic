{
  "$defs": {
    "AdvancedSourceItem": {
      "description": "Advanced source information with linear referencing support.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Confidence value for ML-derived data",
          "title": "Confidence"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id"
        },
        "update_time": {
          "anyOf": [
            {
              "description": "ISO 8601 datetime",
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "When this property was last updated (ISO 8601)",
          "title": "Update Time"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "AdvancedSourceItem",
      "type": "object"
    },
    "AreaBoundaryClass": {
      "description": "Area and boundary class designations.",
      "enum": [
        "land",
        "maritime"
      ],
      "title": "AreaBoundaryClass",
      "type": "string"
    },
    "CartographyContainer": {
      "description": "Cartographic hints for optimal map display.",
      "properties": {
        "max_zoom": {
          "anyOf": [
            {
              "maximum": 23,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum recommended zoom level",
          "title": "Max Zoom"
        },
        "min_zoom": {
          "anyOf": [
            {
              "maximum": 23,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Minimum recommended zoom level",
          "title": "Min Zoom"
        },
        "prominence": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Feature significance/importance",
          "title": "Prominence"
        },
        "sort_key": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Drawing order (lower = on top)",
          "title": "Sort Key"
        }
      },
      "title": "CartographyContainer",
      "type": "object"
    },
    "DivisionAreaProperties": {
      "additionalProperties": true,
      "description": "Properties specific to division area features.",
      "properties": {
        "cartography": {
          "anyOf": [
            {
              "$ref": "#/$defs/CartographyContainer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Cartographic display hints"
        },
        "class": {
          "$ref": "#/$defs/AreaBoundaryClass",
          "description": "Area class (land/maritime)"
        },
        "country": {
          "description": "ISO 3166-1 alpha-2 country code",
          "pattern": "^[A-Z]{2}$",
          "title": "Country",
          "type": "string"
        },
        "division_id": {
          "description": "Referenced division ID (no leading/trailing whitespace)",
          "minLength": 1,
          "pattern": "^(\\S.*)?\\S$",
          "title": "Division Id",
          "type": "string"
        },
        "is_land": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Land area designation",
          "title": "Is Land"
        },
        "is_territorial": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Territorial area designation",
          "title": "Is Territorial"
        },
        "names": {
          "anyOf": [
            {
              "$ref": "#/$defs/NamesContainer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Multilingual names"
        },
        "region": {
          "anyOf": [
            {
              "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ISO 3166-2 region code",
          "title": "Region"
        },
        "sources": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/AdvancedSourceItem"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Advanced source information",
          "title": "Sources"
        },
        "subtype": {
          "$ref": "#/$defs/PlaceType",
          "description": "Administrative level"
        },
        "theme": {
          "description": "Top-level Overture theme",
          "title": "Theme",
          "type": "string"
        },
        "type": {
          "description": "Specific feature type within theme",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "description": "Feature version number",
          "minimum": 0,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "theme",
        "type",
        "version",
        "subtype",
        "class",
        "division_id",
        "country"
      ],
      "title": "DivisionAreaProperties",
      "type": "object"
    },
    "NamePerspectives": {
      "description": "Political perspectives for names.",
      "properties": {
        "countries": {
          "description": "ISO 3166-1 alpha-2 country codes",
          "items": {
            "description": "ISO 3166-1 alpha-2 country code",
            "pattern": "^[A-Z]{2}$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Countries",
          "type": "array"
        },
        "mode": {
          "$ref": "#/$defs/PerspectiveMode",
          "description": "Perspective mode"
        }
      },
      "required": [
        "mode",
        "countries"
      ],
      "title": "NamePerspectives",
      "type": "object"
    },
    "NameRule": {
      "description": "Name rule with variant and language specification.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "language": {
          "anyOf": [
            {
              "description": "IETF BCP-47 language tag",
              "pattern": "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "IETF BCP-47 language tag",
          "title": "Language"
        },
        "perspectives": {
          "anyOf": [
            {
              "$ref": "#/$defs/NamePerspectives"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Political perspectives"
        },
        "side": {
          "anyOf": [
            {
              "enum": [
                "left",
                "right"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Side specification",
          "title": "Side"
        },
        "value": {
          "description": "Name value",
          "minLength": 1,
          "title": "Value",
          "type": "string"
        },
        "variant": {
          "$ref": "#/$defs/NameVariant",
          "description": "Name variant type"
        }
      },
      "required": [
        "variant",
        "value"
      ],
      "title": "NameRule",
      "type": "object"
    },
    "NameVariant": {
      "description": "Name variant types.",
      "enum": [
        "common",
        "official",
        "alternate",
        "short"
      ],
      "title": "NameVariant",
      "type": "string"
    },
    "NamesContainer": {
      "additionalProperties": true,
      "description": "Multilingual names container.",
      "properties": {
        "common": {
          "anyOf": [
            {
              "patternProperties": {
                "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$": {
                  "type": "string"
                }
              },
              "propertyNames": {
                "description": "IETF BCP-47 language tag"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Common names by language",
          "title": "Common"
        },
        "primary": {
          "description": "Primary name",
          "minLength": 1,
          "title": "Primary",
          "type": "string"
        },
        "rules": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/NameRule"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Name rules",
          "title": "Rules"
        }
      },
      "required": [
        "primary"
      ],
      "title": "NamesContainer",
      "type": "object"
    },
    "PerspectiveMode": {
      "description": "Perspective mode for disputed names.",
      "enum": [
        "accepted_by",
        "disputed_by"
      ],
      "title": "PerspectiveMode",
      "type": "string"
    },
    "PlaceType": {
      "description": "Administrative hierarchy levels for divisions.",
      "enum": [
        "country",
        "dependency",
        "macroregion",
        "region",
        "macrocounty",
        "county",
        "localadmin",
        "locality",
        "borough",
        "macrohood",
        "neighborhood",
        "microhood"
      ],
      "title": "PlaceType",
      "type": "string"
    }
  },
  "description": "Division area feature model.",
  "properties": {
    "geometry": {
      "additionalProperties": true,
      "description": "GeoJSON geometry",
      "title": "Geometry",
      "type": "object"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "properties": {
      "$ref": "#/$defs/DivisionAreaProperties",
      "description": "Division area feature properties"
    },
    "type": {
      "default": "Feature",
      "description": "GeoJSON type",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "id",
    "geometry",
    "properties"
  ],
  "title": "DivisionArea",
  "type": "object"
}