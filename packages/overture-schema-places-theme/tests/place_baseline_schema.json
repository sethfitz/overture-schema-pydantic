{
  "$defs": {
    "AddressContainer": {
      "additionalProperties": true,
      "description": "Address container with flexible admin levels.",
      "properties": {
        "address_levels": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/AddressLevel"
              },
              "maxItems": 5,
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Address levels (1-5)",
          "title": "Address Levels"
        },
        "country": {
          "anyOf": [
            {
              "description": "ISO 3166-1 alpha-2 country code",
              "pattern": "^[A-Z]{2}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ISO 3166-1 alpha-2 country code",
          "title": "Country"
        },
        "freeform": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Freeform address string",
          "title": "Freeform"
        },
        "locality": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Locality name",
          "title": "Locality"
        },
        "postal_city": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Postal city if different",
          "title": "Postal City"
        },
        "postcode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Postal code",
          "title": "Postcode"
        },
        "region": {
          "anyOf": [
            {
              "description": "ISO 3166-2 subdivision code",
              "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ISO 3166-2 subdivision code",
          "title": "Region"
        }
      },
      "title": "AddressContainer",
      "type": "object"
    },
    "AddressLevel": {
      "description": "Address level with optional value.",
      "properties": {
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Address level value",
          "title": "Value"
        }
      },
      "title": "AddressLevel",
      "type": "object"
    },
    "NamePerspectives": {
      "description": "Political perspectives for names.",
      "properties": {
        "countries": {
          "description": "ISO 3166-1 alpha-2 country codes",
          "items": {
            "description": "ISO 3166-1 alpha-2 country code",
            "pattern": "^[A-Z]{2}$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Countries",
          "type": "array"
        },
        "mode": {
          "$ref": "#/$defs/PerspectiveMode",
          "description": "Perspective mode"
        }
      },
      "required": [
        "mode",
        "countries"
      ],
      "title": "NamePerspectives",
      "type": "object"
    },
    "NameRule": {
      "description": "Name rule with variant and language specification.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "language": {
          "anyOf": [
            {
              "description": "IETF BCP-47 language tag",
              "pattern": "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "IETF BCP-47 language tag",
          "title": "Language"
        },
        "perspectives": {
          "anyOf": [
            {
              "$ref": "#/$defs/NamePerspectives"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Political perspectives"
        },
        "side": {
          "anyOf": [
            {
              "enum": [
                "left",
                "right"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Side specification",
          "title": "Side"
        },
        "value": {
          "description": "Name value",
          "minLength": 1,
          "title": "Value",
          "type": "string"
        },
        "variant": {
          "$ref": "#/$defs/NameVariant",
          "description": "Name variant type"
        }
      },
      "required": [
        "variant",
        "value"
      ],
      "title": "NameRule",
      "type": "object"
    },
    "NameVariant": {
      "description": "Name variant types.",
      "enum": [
        "common",
        "official",
        "alternate",
        "short"
      ],
      "title": "NameVariant",
      "type": "string"
    },
    "NamesContainer": {
      "additionalProperties": true,
      "description": "Multilingual names container.",
      "properties": {
        "common": {
          "anyOf": [
            {
              "patternProperties": {
                "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$": {
                  "type": "string"
                }
              },
              "propertyNames": {
                "description": "IETF BCP-47 language tag"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Common names by language",
          "title": "Common"
        },
        "primary": {
          "description": "Primary name",
          "minLength": 1,
          "title": "Primary",
          "type": "string"
        },
        "rules": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/NameRule"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Name rules",
          "title": "Rules"
        }
      },
      "required": [
        "primary"
      ],
      "title": "NamesContainer",
      "type": "object"
    },
    "PerspectiveMode": {
      "description": "Perspective mode for disputed names.",
      "enum": [
        "accepted_by",
        "disputed_by"
      ],
      "title": "PerspectiveMode",
      "type": "string"
    },
    "PlaceBrand": {
      "description": "Brand information for places.",
      "properties": {
        "names": {
          "$ref": "#/$defs/NamesContainer",
          "description": "Multilingual brand names"
        },
        "wikidata": {
          "anyOf": [
            {
              "description": "Wikidata identifier (Q followed by digits)",
              "pattern": "^Q\\d+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Wikidata identifier",
          "title": "Wikidata"
        }
      },
      "required": [
        "names"
      ],
      "title": "PlaceBrand",
      "type": "object"
    },
    "PlaceCategories": {
      "description": "Place categories with primary and alternate classification.",
      "properties": {
        "alternate": {
          "anyOf": [
            {
              "items": {
                "description": "Category in snake_case format",
                "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$",
                "type": "string"
              },
              "minItems": 1,
              "type": "array",
              "uniqueItems": true
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Alternate categories",
          "title": "Alternate"
        },
        "primary": {
          "description": "Primary category (required)",
          "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$",
          "title": "Primary",
          "type": "string"
        }
      },
      "required": [
        "primary"
      ],
      "title": "PlaceCategories",
      "type": "object"
    },
    "SourceItem": {
      "description": "Source information for a specific property with optional linear referencing.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Confidence value for ML-derived data",
          "title": "Confidence"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id"
        },
        "update_time": {
          "anyOf": [
            {
              "description": "ISO 8601 datetime",
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "When this property was last updated",
          "title": "Update Time"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "SourceItem",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Place feature model.",
  "properties": {
    "addresses": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/AddressContainer"
          },
          "minItems": 1,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Place addresses",
      "title": "Addresses"
    },
    "brand": {
      "anyOf": [
        {
          "$ref": "#/$defs/PlaceBrand"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Brand information"
    },
    "categories": {
      "anyOf": [
        {
          "$ref": "#/$defs/PlaceCategories"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Place categories"
    },
    "confidence": {
      "anyOf": [
        {
          "description": "Confidence score between 0.0 and 1.0",
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Confidence score (0.0-1.0)",
      "title": "Confidence"
    },
    "emails": {
      "anyOf": [
        {
          "items": {
            "format": "email",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Email addresses",
      "title": "Emails"
    },
    "geometry": {
      "description": "Geometry (Point)",
      "properties": {
        "bbox": {
          "items": {
            "type": "number"
          },
          "minItems": 4,
          "type": "array"
        },
        "coordinates": {
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "type": "array"
        },
        "type": {
          "const": "Point",
          "type": "string"
        }
      },
      "required": [
        "type",
        "coordinates"
      ],
      "title": "Geometry",
      "type": "object"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "names": {
      "anyOf": [
        {
          "$ref": "#/$defs/NamesContainer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Multilingual names"
    },
    "phones": {
      "anyOf": [
        {
          "items": {
            "description": "International phone number (+ followed by country code and number)",
            "pattern": "^\\+\\d{1,3}[\\s\\-\\(\\)0-9]+$",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Phone numbers",
      "title": "Phones"
    },
    "socials": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Social media URLs",
      "title": "Socials"
    },
    "sources": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/SourceItem"
          },
          "minItems": 1,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Source information",
      "title": "Sources"
    },
    "theme": {
      "const": "places",
      "default": "places",
      "description": "Feature theme",
      "title": "Theme",
      "type": "string"
    },
    "type": {
      "const": "place",
      "default": "place",
      "description": "Feature type",
      "title": "Type",
      "type": "string"
    },
    "version": {
      "description": "Feature version number",
      "minimum": 0,
      "title": "Version",
      "type": "integer"
    },
    "websites": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Website URLs",
      "title": "Websites"
    }
  },
  "required": [
    "id",
    "geometry",
    "version"
  ],
  "title": "Place",
  "type": "object"
}