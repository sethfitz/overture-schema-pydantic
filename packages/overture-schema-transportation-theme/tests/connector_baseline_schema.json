{
  "$defs": {
    "SourceItem": {
      "additionalProperties": false,
      "description": "Source information for a specific property.",
      "properties": {
        "between": {
          "default": null,
          "description": "Linear referencing range",
          "items": {
            "maximum": 1.0,
            "minimum": 0.0,
            "type": "number"
          },
          "maxItems": 2,
          "minItems": 2,
          "title": "Between",
          "type": "array"
        },
        "confidence": {
          "default": null,
          "description": "Confidence value for ML-derived data",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id",
          "type": "string"
        },
        "update_time": {
          "default": null,
          "description": "When this property was last updated",
          "format": "date-time",
          "title": "Update Time",
          "type": "string"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "SourceItem",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Connector feature model.",
  "patternProperties": {
    "^ext_.*$": {
      "description": "Additional top-level properties must be prefixed with `ext_`."
    }
  },
  "properties": {
    "geometry": {
      "description": "Geometry (Point)",
      "properties": {
        "bbox": {
          "items": {
            "type": "number"
          },
          "minItems": 4,
          "type": "array"
        },
        "coordinates": {
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "type": "array"
        },
        "type": {
          "const": "Point",
          "type": "string"
        }
      },
      "required": [
        "type",
        "coordinates"
      ],
      "title": "Geometry",
      "type": "object"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "properties": {
      "additionalProperties": false,
      "patternProperties": {
        "^ext_.*$": {
          "description": "Additional top-level properties must be prefixed with `ext_`."
        }
      },
      "properties": {
        "sources": {
          "default": null,
          "description": "Source information",
          "items": {
            "$ref": "#/$defs/SourceItem"
          },
          "title": "Sources",
          "type": "array"
        },
        "theme": {
          "const": "transportation",
          "description": "Feature theme",
          "title": "Theme",
          "type": "string"
        },
        "type": {
          "const": "connector",
          "description": "Feature type",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "description": "Feature version number",
          "minimum": 0,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "theme",
        "type",
        "version"
      ],
      "type": "object",
      "unevaluatedProperties": false
    },
    "type": {
      "const": "Feature",
      "type": "string"
    }
  },
  "required": [
    "id",
    "geometry",
    "properties",
    "type"
  ],
  "title": "Connector",
  "type": "object"
}