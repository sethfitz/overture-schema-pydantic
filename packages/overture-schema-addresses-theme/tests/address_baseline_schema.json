{
  "$defs": {
    "AddressLevel": {
      "description": "Single administrative level in address hierarchy.",
      "properties": {
        "value": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Administrative level value (no leading/trailing whitespace)",
          "title": "Value"
        }
      },
      "title": "AddressLevel",
      "type": "object"
    },
    "SourceItem": {
      "description": "Source information for a specific property with optional linear referencing.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Confidence value for ML-derived data",
          "title": "Confidence"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id"
        },
        "update_time": {
          "anyOf": [
            {
              "description": "ISO 8601 datetime",
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "When this property was last updated",
          "title": "Update Time"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "SourceItem",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Address feature model.",
  "properties": {
    "address_levels": {
      "description": "Administrative levels (1-5), ordered highest first",
      "items": {
        "$ref": "#/$defs/AddressLevel"
      },
      "maxItems": 5,
      "minItems": 1,
      "title": "Address Levels",
      "type": "array"
    },
    "country": {
      "description": "ISO 3166-1 alpha-2 country code",
      "pattern": "^[A-Z]{2}$",
      "title": "Country",
      "type": "string"
    },
    "geometry": {
      "description": "Geometry (Point)",
      "properties": {
        "bbox": {
          "items": {
            "type": "number"
          },
          "minItems": 4,
          "type": "array"
        },
        "coordinates": {
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "type": "array"
        },
        "type": {
          "const": "Point",
          "type": "string"
        }
      },
      "required": [
        "type",
        "coordinates"
      ],
      "title": "Geometry",
      "type": "object"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "number": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "House/building number (no leading/trailing whitespace)",
      "title": "Number"
    },
    "postal_city": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Alternative city name for mailing (no leading/trailing whitespace)",
      "title": "Postal City"
    },
    "postcode": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Postal/ZIP code (no leading/trailing whitespace)",
      "title": "Postcode"
    },
    "sources": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/SourceItem"
          },
          "minItems": 1,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Source information",
      "title": "Sources"
    },
    "street": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Street name (no leading/trailing whitespace)",
      "title": "Street"
    },
    "theme": {
      "const": "addresses",
      "default": "addresses",
      "description": "Feature theme",
      "title": "Theme",
      "type": "string"
    },
    "type": {
      "const": "address",
      "default": "address",
      "description": "Feature type",
      "title": "Type",
      "type": "string"
    },
    "unit": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Suite/apartment/floor number (no leading/trailing whitespace)",
      "title": "Unit"
    },
    "version": {
      "description": "Feature version number",
      "minimum": 0,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "id",
    "geometry",
    "version",
    "country",
    "address_levels"
  ],
  "title": "Address",
  "type": "object"
}