{
  "$defs": {
    "AreaBoundaryClass": {
      "description": "Area and boundary class designations.",
      "enum": [
        "land",
        "maritime"
      ],
      "title": "AreaBoundaryClass",
      "type": "string"
    },
    "PerspectiveMode": {
      "description": "Political perspective validation modes.",
      "enum": [
        "accepted_by",
        "disputed_by"
      ],
      "title": "PerspectiveMode",
      "type": "string"
    },
    "Perspectives": {
      "description": "Political perspectives container.",
      "properties": {
        "countries": {
          "description": "ISO 3166-1 alpha-2 country codes",
          "items": {
            "description": "ISO 3166-1 alpha-2 country code",
            "pattern": "^[A-Z]{2}$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Countries",
          "type": "array",
          "uniqueItems": true
        },
        "mode": {
          "$ref": "#/$defs/PerspectiveMode",
          "description": "Perspective validation mode"
        }
      },
      "required": [
        "mode",
        "countries"
      ],
      "title": "Perspectives",
      "type": "object"
    },
    "PlaceType": {
      "description": "Administrative hierarchy levels for divisions.",
      "enum": [
        "country",
        "dependency",
        "macroregion",
        "region",
        "macrocounty",
        "county",
        "localadmin",
        "locality",
        "borough",
        "macrohood",
        "neighborhood",
        "microhood"
      ],
      "title": "PlaceType",
      "type": "string"
    },
    "SourceItem": {
      "description": "Source information for a specific property with optional linear referencing.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Confidence value for ML-derived data",
          "title": "Confidence"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id"
        },
        "update_time": {
          "anyOf": [
            {
              "description": "ISO 8601 datetime",
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "When this property was last updated",
          "title": "Update Time"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "SourceItem",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Division boundary feature model.",
  "properties": {
    "class": {
      "$ref": "#/$defs/AreaBoundaryClass",
      "description": "Boundary class (land/maritime)"
    },
    "country": {
      "anyOf": [
        {
          "description": "ISO 3166-1 alpha-2 country code",
          "pattern": "^[A-Z]{2}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "ISO 3166-1 alpha-2 country code (not for country boundaries)",
      "title": "Country"
    },
    "division_ids": {
      "description": "Two division IDs (left/right)",
      "items": {
        "type": "string"
      },
      "maxItems": 2,
      "minItems": 2,
      "title": "Division Ids",
      "type": "array",
      "uniqueItems": true
    },
    "geometry": {
      "description": "Geometry (LineString or MultiLineString)",
      "oneOf": [
        {
          "properties": {
            "bbox": {
              "items": {
                "type": "number"
              },
              "minItems": 4,
              "type": "array"
            },
            "coordinates": {
              "items": {
                "items": {
                  "type": "number"
                },
                "minItems": 2,
                "type": "array"
              },
              "minItems": 2,
              "type": "array"
            },
            "type": {
              "const": "LineString",
              "type": "string"
            }
          },
          "required": [
            "type",
            "coordinates"
          ],
          "type": "object"
        },
        {
          "properties": {
            "bbox": {
              "items": {
                "type": "number"
              },
              "minItems": 4,
              "type": "array"
            },
            "coordinates": {
              "items": {
                "items": {
                  "items": {
                    "type": "number"
                  },
                  "minItems": 2,
                  "type": "array"
                },
                "minItems": 2,
                "type": "array"
              },
              "minItems": 1,
              "type": "array"
            },
            "type": {
              "const": "MultiLineString",
              "type": "string"
            }
          },
          "required": [
            "type",
            "coordinates"
          ],
          "type": "object"
        }
      ],
      "title": "Geometry"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "is_disputed": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Boundary is disputed",
      "title": "Is Disputed"
    },
    "is_land": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Land boundary designation",
      "title": "Is Land"
    },
    "is_territorial": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Territorial boundary designation",
      "title": "Is Territorial"
    },
    "perspectives": {
      "anyOf": [
        {
          "$ref": "#/$defs/Perspectives"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Political perspectives"
    },
    "region": {
      "anyOf": [
        {
          "description": "ISO 3166-2 subdivision code",
          "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "ISO 3166-2 region code",
      "title": "Region"
    },
    "sources": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/SourceItem"
          },
          "minItems": 1,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Source information",
      "title": "Sources"
    },
    "subtype": {
      "$ref": "#/$defs/PlaceType",
      "description": "Administrative level"
    },
    "theme": {
      "const": "divisions",
      "default": "divisions",
      "description": "Feature theme",
      "title": "Theme",
      "type": "string"
    },
    "type": {
      "const": "division_boundary",
      "default": "division_boundary",
      "description": "Feature type",
      "title": "Type",
      "type": "string"
    },
    "version": {
      "description": "Feature version number",
      "minimum": 0,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "id",
    "geometry",
    "version",
    "subtype",
    "class",
    "division_ids"
  ],
  "title": "DivisionBoundary",
  "type": "object"
}