      ],
      "title": "LandUseSubtype",
      "type": "string"
    },
    "NamePerspectives": {
      "description": "Political perspectives for names.",
      "properties": {
        "countries": {
          "description": "ISO 3166-1 alpha-2 country codes",
          "items": {
            "description": "ISO 3166-1 alpha-2 country code",
            "pattern": "^[A-Z]{2}$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Countries",
          "type": "array"
        },
        "mode": {
          "$ref": "#/$defs/PerspectiveMode",
          "description": "Perspective mode"
        }
      },
      "required": [
        "mode",
        "countries"
      ],
      "title": "NamePerspectives",
      "type": "object"
    },
    "NameRule": {
      "description": "Name rule with variant and language specification.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "language": {
          "anyOf": [
            {
              "description": "IETF BCP-47 language tag",
              "pattern": "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "IETF BCP-47 language tag",
          "title": "Language"
        },
        "perspectives": {
          "anyOf": [
            {
              "$ref": "#/$defs/NamePerspectives"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Political perspectives"
        },
        "side": {
          "anyOf": [
            {
              "enum": [
                "left",
                "right"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Side specification",
          "title": "Side"
        },
        "value": {
          "description": "Name value",
          "minLength": 1,
          "title": "Value",
          "type": "string"
        },
        "variant": {
          "$ref": "#/$defs/NameVariant",
          "description": "Name variant type"
        }
      },
      "required": [
        "variant",
        "value"
      ],
      "title": "NameRule",
      "type": "object"
    },
    "NameVariant": {
      "description": "Name variant types.",
      "enum": [
        "common",
        "official",
        "alternate",
        "short"
      ],
      "title": "NameVariant",
      "type": "string"
    },
    "NamesContainer": {
      "additionalProperties": true,
      "description": "Multilingual names container.",
      "properties": {
        "common": {
          "anyOf": [
            {
              "patternProperties": {
                "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$": {
                  "type": "string"
                }
              },
              "propertyNames": {
                "description": "IETF BCP-47 language tag"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Common names by language",
          "title": "Common"
        },
        "primary": {
          "description": "Primary name",
          "minLength": 1,
          "title": "Primary",
          "type": "string"
        },
        "rules": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/NameRule"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Name rules",
          "title": "Rules"
        }
      },
      "required": [
        "primary"
      ],
      "title": "NamesContainer",
      "type": "object"
    },
    "PerspectiveMode": {
      "description": "Perspective mode for disputed names.",
      "enum": [
        "accepted_by",
        "disputed_by"
      ],
      "title": "PerspectiveMode",
      "type": "string"
    },
    "SourceItem": {
      "description": "Source information for a specific property with optional linear referencing.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Confidence value for ML-derived data",
          "title": "Confidence"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id"
        },
        "update_time": {
          "anyOf": [
            {
              "description": "ISO 8601 datetime",
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "When this property was last updated",
          "title": "Update Time"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "SourceItem",
      "type": "object"
    },
    "SurfaceMaterial": {
      "description": "Surface material enum used by infrastructure and land features.",
      "enum": [
        "asphalt",
        "cobblestone",
        "compacted",
        "concrete",
        "concrete_plates",
        "dirt",
        "earth",
        "fine_gravel",
        "grass",
        "gravel",
        "ground",
        "paved",
        "paving_stones",
        "pebblestone",
        "recreation_grass",
        "recreation_paved",
        "recreation_sand",
        "rubber",
        "sand",
        "sett",
        "tartan",
        "unpaved",
        "wood",
        "woodchips"
      ],
      "title": "SurfaceMaterial",
      "type": "string"
    }
  },
  "additionalProperties": true,
  "description": "LandUse feature model for classifications of human use of land.",
  "properties": {
    "class": {
      "$ref": "#/$defs/LandUseClass",
      "description": "Further classification of the land use"
    },
    "elevation": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Elevation in meters",
      "title": "Elevation"
    },
    "geometry": {
      "description": "Geometry (Point, LineString, Polygon, or MultiPolygon)",
      "oneOf": [
        {
          "properties": {
            "bbox": {
              "items": {
                "type": "number"
              },
              "minItems": 4,
              "type": "array"
            },
            "coordinates": {
              "items": {
                "items": {
                  "type": "number"
                },
                "minItems": 2,
                "type": "array"
              },
              "minItems": 2,
              "type": "array"
            },
            "type": {
              "const": "LineString",
              "type": "string"
            }
          },
          "required": [
            "type",
            "coordinates"
          ],
          "type": "object"
        },
        {
          "properties": {
            "bbox": {
              "items": {
                "type": "number"
              },
              "minItems": 4,
              "type": "array"
            },
            "coordinates": {
              "items": {
                "items": {
                  "items": {
                    "items": {
                      "type": "number"
                    },
                    "minItems": 2,
                    "type": "array"
                  },
                  "minItems": 4,
                  "type": "array"
                },
                "minItems": 1,
                "type": "array"
              },
              "minItems": 1,
              "type": "array"
            },
            "type": {
              "const": "MultiPolygon",
              "type": "string"
            }
          },
          "required": [
            "type",
            "coordinates"
          ],
          "type": "object"
        },
        {
          "properties": {
            "bbox": {
              "items": {
                "type": "number"
              },
              "minItems": 4,
              "type": "array"
            },
            "coordinates": {
              "items": {
                "type": "number"
              },
              "minItems": 2,
              "type": "array"
            },
            "type": {
              "const": "Point",
              "type": "string"
            }
          },
          "required": [
            "type",
            "coordinates"
          ],
          "type": "object"
        },
        {
          "properties": {
            "bbox": {
              "items": {
                "type": "number"
              },
              "minItems": 4,
              "type": "array"
            },
            "coordinates": {
              "items": {
                "items": {
                  "items": {
                    "type": "number"
                  },
                  "minItems": 2,
                  "type": "array"
                },
                "minItems": 4,
                "type": "array"
              },
              "minItems": 1,
              "type": "array"
            },
            "type": {
              "const": "Polygon",
              "type": "string"
            }
          },
          "required": [
            "type",
            "coordinates"
          ],
          "type": "object"
        }
      ],
      "title": "Geometry"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "level": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Z-order level",
      "title": "Level"
    },
    "names": {
      "anyOf": [
        {
          "$ref": "#/$defs/NamesContainer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Multilingual names"
    },
    "source_tags": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Source tags from data providers",
      "title": "Source Tags"
    },
    "sources": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/SourceItem"
          },
          "minItems": 1,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Source information",
      "title": "Sources"
    },
    "subtype": {
      "$ref": "#/$defs/LandUseSubtype",
      "description": "Broad type of land"
    },
    "surface": {
      "anyOf": [
        {
          "$ref": "#/$defs/SurfaceMaterial"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Surface material"
    },
    "theme": {
      "const": "base",
      "default": "base",
      "description": "Feature theme",
      "title": "Theme",
      "type": "string"
    },
    "type": {
      "const": "land_use",
      "default": "land_use",
      "description": "Feature type",
      "title": "Type",
      "type": "string"
    },
    "version": {
      "description": "Feature version number",
      "minimum": 0,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "id",
    "geometry",
    "version",
    "subtype",
    "class"
  ],
  "title": "LandUse",
  "type": "object"
}