{
  "$defs": {
    "AccessRestrictionRule": {
      "additionalProperties": true,
      "description": "Access restriction rule with scoping via when clause.",
      "properties": {
        "access_type": {
          "$ref": "#/$defs/AccessType",
          "description": "Access type"
        },
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range [start, end] where 0=start, 1=end of feature",
          "title": "Between"
        },
        "when": {
          "anyOf": [
            {
              "$ref": "#/$defs/AccessRestrictionWhenClause"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Scoping conditions"
        }
      },
      "required": [
        "access_type"
      ],
      "title": "AccessRestrictionRule",
      "type": "object"
    },
    "AccessRestrictionWhenClause": {
      "description": "When clause for access restriction rules.",
      "properties": {
        "during": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Time periods in OSM opening hours format (e.g., 'Mo-Fr 08:00-17:00')",
          "title": "During"
        },
        "heading": {
          "anyOf": [
            {
              "enum": [
                "forward",
                "backward"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Direction of travel: 'forward' follows feature geometry, 'backward' opposes it",
          "title": "Heading"
        },
        "mode": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/TravelMode"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Transportation modes affected by this rule (car, foot, bike, etc.)",
          "title": "Mode"
        },
        "recognized": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/RecognizedStatus"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Legal or social recognition status (as_private, as_employee, as_public, etc.)",
          "title": "Recognized"
        },
        "using": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/PurposeOfUse"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Purpose of travel (to_deliver, at_destination, for_through_traffic, etc.)",
          "title": "Using"
        },
        "vehicle": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/VehicleConstraint"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Physical vehicle constraints (weight, height, width, length limits)",
          "title": "Vehicle"
        }
      },
      "title": "AccessRestrictionWhenClause",
      "type": "object"
    },
    "AccessType": {
      "description": "Access level enumeration.",
      "enum": [
        "allowed",
        "denied",
        "designated"
      ],
      "title": "AccessType",
      "type": "string"
    },
    "ConnectorReference": {
      "description": "Reference to a connector with position information.",
      "properties": {
        "at": {
          "description": "Position along segment (0.0-1.0)",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "At",
          "type": "number"
        },
        "connector_id": {
          "description": "Connector identifier",
          "title": "Connector Id",
          "type": "string"
        }
      },
      "required": [
        "connector_id",
        "at"
      ],
      "title": "ConnectorReference",
      "type": "object"
    },
    "DestinationLabel": {
      "description": "Destination label with type classification.",
      "properties": {
        "type": {
          "$ref": "#/$defs/DestinationLabelType",
          "description": "Label type"
        },
        "value": {
          "description": "Label text",
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "value",
        "type"
      ],
      "title": "DestinationLabel",
      "type": "object"
    },
    "DestinationLabelType": {
      "description": "Destination label type classification.",
      "enum": [
        "unknown",
        "street",
        "route_ref",
        "toward_route_ref"
      ],
      "title": "DestinationLabelType",
      "type": "string"
    },
    "DestinationRule": {
      "description": "Destination signage rule with scoping via when clause.",
      "properties": {
        "final_heading": {
          "$ref": "#/$defs/HeadingType",
          "description": "Final direction on target segment"
        },
        "from_connector_id": {
          "description": "Source connector identifier",
          "title": "From Connector Id",
          "type": "string"
        },
        "labels": {
          "description": "Destination labels",
          "items": {
            "$ref": "#/$defs/DestinationLabel"
          },
          "minItems": 1,
          "title": "Labels",
          "type": "array",
          "uniqueItems": true
        },
        "symbols": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/DestinationSignSymbol"
              },
              "type": "array",
              "uniqueItems": true
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Route symbols",
          "title": "Symbols"
        },
        "to_connector_id": {
          "description": "Target connector identifier",
          "title": "To Connector Id",
          "type": "string"
        },
        "to_segment_id": {
          "description": "Target segment identifier",
          "title": "To Segment Id",
          "type": "string"
        },
        "when": {
          "anyOf": [
            {
              "$ref": "#/$defs/DestinationWhenClause"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Scoping conditions"
        }
      },
      "required": [
        "from_connector_id",
        "to_connector_id",
        "to_segment_id",
        "final_heading",
        "labels"
      ],
      "title": "DestinationRule",
      "type": "object"
    },
    "DestinationSignSymbol": {
      "description": "Valid destination sign symbols.",
      "enum": [
        "motorway",
        "airport",
        "hospital",
        "center",
        "industrial",
        "parking"
      ],
      "title": "DestinationSignSymbol",
      "type": "string"
    },
    "DestinationWhenClause": {
      "description": "When clause for destination rules.",
      "properties": {
        "heading": {
          "anyOf": [
            {
              "enum": [
                "forward",
                "backward"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Direction of travel: 'forward' follows feature geometry, 'backward' opposes it",
          "title": "Heading"
        }
      },
      "title": "DestinationWhenClause",
      "type": "object"
    },
    "HeadingType": {
      "description": "Heading type classification.",
      "enum": [
        "forward",
        "backward"
      ],
      "title": "HeadingType",
      "type": "string"
    },
    "LevelRule": {
      "additionalProperties": true,
      "description": "Level/elevation rule with linear referencing.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range [start, end] where 0=start, 1=end of feature",
          "title": "Between"
        },
        "value": {
          "description": "Level/elevation value",
          "title": "Value",
          "type": "integer"
        }
      },
      "required": [
        "value"
      ],
      "title": "LevelRule",
      "type": "object"
    },
    "NamePerspectives": {
      "description": "Political perspectives for names.",
      "properties": {
        "countries": {
          "description": "ISO 3166-1 alpha-2 country codes",
          "items": {
            "description": "ISO 3166-1 alpha-2 country code",
            "pattern": "^[A-Z]{2}$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Countries",
          "type": "array"
        },
        "mode": {
          "$ref": "#/$defs/PerspectiveMode",
          "description": "Perspective mode"
        }
      },
      "required": [
        "mode",
        "countries"
      ],
      "title": "NamePerspectives",
      "type": "object"
    },
    "NameRule": {
      "description": "Name rule with variant and language specification.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "language": {
          "anyOf": [
            {
              "description": "IETF BCP-47 language tag",
              "pattern": "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "IETF BCP-47 language tag",
          "title": "Language"
        },
        "perspectives": {
          "anyOf": [
            {
              "$ref": "#/$defs/NamePerspectives"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Political perspectives"
        },
        "side": {
          "anyOf": [
            {
              "enum": [
                "left",
                "right"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Side specification",
          "title": "Side"
        },
        "value": {
          "description": "Name value",
          "minLength": 1,
          "title": "Value",
          "type": "string"
        },
        "variant": {
          "$ref": "#/$defs/NameVariant",
          "description": "Name variant type"
        }
      },
      "required": [
        "variant",
        "value"
      ],
      "title": "NameRule",
      "type": "object"
    },
    "NameVariant": {
      "description": "Name variant types.",
      "enum": [
        "common",
        "official",
        "alternate",
        "short"
      ],
      "title": "NameVariant",
      "type": "string"
    },
    "NamesContainer": {
      "additionalProperties": true,
      "description": "Multilingual names container.",
      "properties": {
        "common": {
          "anyOf": [
            {
              "patternProperties": {
                "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$": {
                  "type": "string"
                }
              },
              "propertyNames": {
                "description": "IETF BCP-47 language tag"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Common names by language",
          "title": "Common"
        },
        "primary": {
          "description": "Primary name",
          "minLength": 1,
          "title": "Primary",
          "type": "string"
        },
        "rules": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/NameRule"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Name rules",
          "title": "Rules"
        }
      },
      "required": [
        "primary"
      ],
      "title": "NamesContainer",
      "type": "object"
    },
    "PerspectiveMode": {
      "description": "Perspective mode for disputed names.",
      "enum": [
        "accepted_by",
        "disputed_by"
      ],
      "title": "PerspectiveMode",
      "type": "string"
    },
    "ProhibitedTransitionRule": {
      "additionalProperties": true,
      "description": "Prohibited transition (turn restriction) rule.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range [start, end] where 0=start, 1=end of feature",
          "title": "Between"
        },
        "final_heading": {
          "$ref": "#/$defs/HeadingType",
          "description": "Required final heading"
        },
        "sequence": {
          "description": "Sequence of connectors defining the prohibited path",
          "items": {
            "$ref": "#/$defs/ProhibitedTransitionSequence"
          },
          "minItems": 1,
          "title": "Sequence",
          "type": "array",
          "uniqueItems": true
        },
        "when": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProhibitedTransitionWhenClause"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Scoping conditions"
        }
      },
      "required": [
        "sequence",
        "final_heading"
      ],
      "title": "ProhibitedTransitionRule",
      "type": "object"
    },
    "ProhibitedTransitionSequence": {
      "description": "Sequence entry with connector and segment identifiers.",
      "properties": {
        "connector_id": {
          "description": "Connector identifier",
          "title": "Connector Id",
          "type": "string"
        },
        "segment_id": {
          "description": "Segment identifier",
          "title": "Segment Id",
          "type": "string"
        }
      },
      "required": [
        "connector_id",
        "segment_id"
      ],
      "title": "ProhibitedTransitionSequence",
      "type": "object"
    },
    "ProhibitedTransitionWhenClause": {
      "description": "When clause for prohibited transition rules.",
      "properties": {
        "during": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Time periods in OSM opening hours format (e.g., 'Mo-Fr 08:00-17:00')",
          "title": "During"
        },
        "heading": {
          "anyOf": [
            {
              "enum": [
                "forward",
                "backward"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Direction of travel: 'forward' follows feature geometry, 'backward' opposes it",
          "title": "Heading"
        },
        "mode": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/TravelMode"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Transportation modes affected by this rule (car, foot, bike, etc.)",
          "title": "Mode"
        },
        "recognized": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/RecognizedStatus"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Legal or social recognition status (as_private, as_employee, as_public, etc.)",
          "title": "Recognized"
        },
        "using": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/PurposeOfUse"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Purpose of travel (to_deliver, at_destination, for_through_traffic, etc.)",
          "title": "Using"
        },
        "vehicle": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/VehicleConstraint"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Physical vehicle constraints (weight, height, width, length limits)",
          "title": "Vehicle"
        }
      },
      "title": "ProhibitedTransitionWhenClause",
      "type": "object"
    },
    "PurposeOfUse": {
      "description": "Purpose of use enumeration.",
      "enum": [
        "to_deliver",
        "at_destination",
        "through_traffic",
        "as_customer",
        "to_farm"
      ],
      "title": "PurposeOfUse",
      "type": "string"
    },
    "RailFlagRule": {
      "additionalProperties": true,
      "description": "Rail-specific flag rule with geometric scoping only.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range [start, end] where 0=start, 1=end of feature",
          "title": "Between"
        },
        "values": {
          "description": "Rail flag values",
          "items": {
            "$ref": "#/$defs/RailFlagType"
          },
          "minItems": 1,
          "title": "Values",
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "values"
      ],
      "title": "RailFlagRule",
      "type": "object"
    },
    "RailFlagType": {
      "description": "Rail-specific flag types.",
      "enum": [
        "is_bridge",
        "is_tunnel",
        "is_under_construction",
        "is_abandoned",
        "is_covered",
        "is_passenger",
        "is_freight",
        "is_disused"
      ],
      "title": "RailFlagType",
      "type": "string"
    },
    "RecognizedStatus": {
      "description": "Recognized status enumeration.",
      "enum": [
        "as_private",
        "as_employee",
        "as_customer",
        "as_resident",
        "as_permitted"
      ],
      "title": "RecognizedStatus",
      "type": "string"
    },
    "RoadFlagRule": {
      "additionalProperties": true,
      "description": "Road-specific flag rule with geometric scoping only.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range [start, end] where 0=start, 1=end of feature",
          "title": "Between"
        },
        "values": {
          "description": "Road flag values",
          "items": {
            "$ref": "#/$defs/RoadFlagType"
          },
          "minItems": 1,
          "title": "Values",
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "values"
      ],
      "title": "RoadFlagRule",
      "type": "object"
    },
    "RoadFlagType": {
      "description": "Road-specific flag types.",
      "enum": [
        "is_bridge",
        "is_link",
        "is_tunnel",
        "is_under_construction",
        "is_abandoned",
        "is_covered",
        "is_indoor"
      ],
      "title": "RoadFlagType",
      "type": "string"
    },
    "RoadSurface": {
      "description": "Road surface material types.",
      "enum": [
        "unknown",
        "paved",
        "unpaved",
        "gravel",
        "dirt",
        "paving_stones",
        "metal"
      ],
      "title": "RoadSurface",
      "type": "string"
    },
    "RouteReference": {
      "additionalProperties": true,
      "description": "Route reference with linear referencing support.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range [start, end] where 0=start, 1=end of feature",
          "title": "Between"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Route name",
          "title": "Name"
        },
        "network": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Route network",
          "title": "Network"
        },
        "ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Route reference number",
          "title": "Ref"
        },
        "symbol": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Route symbol URL",
          "title": "Symbol"
        },
        "wikidata": {
          "anyOf": [
            {
              "description": "Wikidata identifier (Q followed by digits)",
              "pattern": "^Q\\d+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Wikidata identifier",
          "title": "Wikidata"
        }
      },
      "title": "RouteReference",
      "type": "object"
    },
    "SegmentSubtype": {
      "description": "Transportation segment subtype classification.",
      "enum": [
        "road",
        "rail",
        "water"
      ],
      "title": "SegmentSubtype",
      "type": "string"
    },
    "SourceItem": {
      "description": "Source information for a specific property with optional linear referencing.",
      "properties": {
        "between": {
          "anyOf": [
            {
