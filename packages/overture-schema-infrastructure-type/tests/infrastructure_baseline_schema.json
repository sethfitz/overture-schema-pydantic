{
  "$defs": {
    "InfrastructureClass": {
      "description": "Infrastructure class classification.",
      "enum": [
        "airport",
        "airstrip",
        "runway",
        "taxiway",
        "terminal",
        "helipad",
        "bridge",
        "bridge_support",
        "viaduct",
        "generator",
        "power_line",
        "power_pole",
        "power_tower",
        "substation",
        "bus_station",
        "railway_station",
        "ferry_terminal",
        "fence",
        "wall",
        "gate",
        "bollard",
        "communication_tower",
        "mobile_phone_tower"
      ],
      "title": "InfrastructureClass",
      "type": "string"
    },
    "InfrastructureSubtype": {
      "description": "Infrastructure subtype classification.",
      "enum": [
        "aerialway",
        "airport",
        "barrier",
        "bridge",
        "communication",
        "emergency",
        "manhole",
        "pedestrian",
        "pier",
        "power",
        "recreation",
        "tower",
        "transit",
        "transportation",
        "utility",
        "waste_management",
        "water"
      ],
      "title": "InfrastructureSubtype",
      "type": "string"
    },
    "NamePerspectives": {
      "description": "Political perspectives for names.",
      "properties": {
        "countries": {
          "description": "ISO 3166-1 alpha-2 country codes",
          "items": {
            "description": "ISO 3166-1 alpha-2 country code",
            "pattern": "^[A-Z]{2}$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Countries",
          "type": "array"
        },
        "mode": {
          "$ref": "#/$defs/PerspectiveMode",
          "description": "Perspective mode"
        }
      },
      "required": [
        "mode",
        "countries"
      ],
      "title": "NamePerspectives",
      "type": "object"
    },
    "NameRule": {
      "description": "Name rule with variant and language specification.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "language": {
          "anyOf": [
            {
              "description": "IETF BCP-47 language tag",
              "pattern": "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "IETF BCP-47 language tag",
          "title": "Language"
        },
        "perspectives": {
          "anyOf": [
            {
              "$ref": "#/$defs/NamePerspectives"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Political perspectives"
        },
        "side": {
          "anyOf": [
            {
              "enum": [
                "left",
                "right"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Side specification",
          "title": "Side"
        },
        "value": {
          "description": "Name value",
          "minLength": 1,
          "title": "Value",
          "type": "string"
        },
        "variant": {
          "$ref": "#/$defs/NameVariant",
          "description": "Name variant type"
        }
      },
      "required": [
        "variant",
        "value"
      ],
      "title": "NameRule",
      "type": "object"
    },
    "NameVariant": {
      "description": "Name variant types.",
      "enum": [
        "common",
        "official",
        "alternate",
        "short"
      ],
      "title": "NameVariant",
      "type": "string"
    },
    "NamesContainer": {
      "additionalProperties": true,
      "description": "Multilingual names container.",
      "properties": {
        "common": {
          "anyOf": [
            {
              "patternProperties": {
                "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$": {
                  "type": "string"
                }
              },
              "propertyNames": {
                "description": "IETF BCP-47 language tag"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Common names by language",
          "title": "Common"
        },
        "primary": {
          "description": "Primary name",
          "minLength": 1,
          "title": "Primary",
          "type": "string"
        },
        "rules": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/NameRule"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Name rules",
          "title": "Rules"
        }
      },
      "required": [
        "primary"
      ],
      "title": "NamesContainer",
      "type": "object"
    },
    "PerspectiveMode": {
      "description": "Perspective mode for disputed names.",
      "enum": [
        "accepted_by",
        "disputed_by"
      ],
      "title": "PerspectiveMode",
      "type": "string"
    },
    "SourceItem": {
      "description": "Source information for a specific property with optional linear referencing.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Confidence value for ML-derived data",
          "title": "Confidence"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id"
        },
        "update_time": {
          "anyOf": [
            {
              "description": "ISO 8601 datetime",
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "When this property was last updated",
          "title": "Update Time"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "SourceItem",
      "type": "object"
    },
    "SurfaceMaterial": {
      "description": "Surface material enum used by infrastructure and land features.",
      "enum": [
        "asphalt",
        "cobblestone",
        "compacted",
        "concrete",
        "concrete_plates",
