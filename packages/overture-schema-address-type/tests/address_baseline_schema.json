{
  "$defs": {
    "AddressLevel": {
      "description": "Single administrative level in address hierarchy.",
      "properties": {
        "value": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Administrative level value (no leading/trailing whitespace)",
          "title": "Value"
        }
      },
      "title": "AddressLevel",
      "type": "object"
    },
    "AddressProperties": {
      "additionalProperties": true,
      "description": "Properties specific to address features.",
      "properties": {
        "address_levels": {
          "description": "Administrative levels (1-5), ordered highest first",
          "items": {
            "$ref": "#/$defs/AddressLevel"
          },
          "maxItems": 5,
          "minItems": 1,
          "title": "Address Levels",
          "type": "array"
        },
        "cartography": {
          "anyOf": [
            {
              "$ref": "#/$defs/CartographyContainer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Cartographic display hints"
        },
        "country": {
          "description": "ISO 3166-1 alpha-2 country code",
          "pattern": "^[A-Z]{2}$",
          "title": "Country",
          "type": "string"
        },
        "number": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "House/building number (no leading/trailing whitespace)",
          "title": "Number"
        },
        "postal_city": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Alternative city name for mailing (no leading/trailing whitespace)",
          "title": "Postal City"
        },
        "postcode": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Postal/ZIP code (no leading/trailing whitespace)",
          "title": "Postcode"
        },
        "sources": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/AdvancedSourceItem"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Advanced source information",
          "title": "Sources"
        },
        "street": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Street name (no leading/trailing whitespace)",
          "title": "Street"
        },
        "theme": {
          "const": "addresses",
          "default": "addresses",
          "description": "Feature theme",
          "title": "Theme",
          "type": "string"
        },
        "type": {
          "const": "address",
          "default": "address",
          "description": "Feature type",
          "title": "Type",
          "type": "string"
        },
        "unit": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Suite/apartment/floor number (no leading/trailing whitespace)",
          "title": "Unit"
        },
        "version": {
          "description": "Feature version number",
          "minimum": 0,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "version",
        "country",
        "address_levels"
      ],
      "title": "AddressProperties",
      "type": "object"
    },
    "AdvancedSourceItem": {
      "description": "Advanced source information with linear referencing support.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Confidence value for ML-derived data",
          "title": "Confidence"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id"
        },
        "update_time": {
          "anyOf": [
            {
              "description": "ISO 8601 datetime",
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "When this property was last updated (ISO 8601)",
          "title": "Update Time"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "AdvancedSourceItem",
      "type": "object"
    },
    "CartographyContainer": {
      "description": "Cartographic hints for optimal map display.",
      "properties": {
        "max_zoom": {
          "anyOf": [
            {
              "maximum": 23,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum recommended zoom level",
          "title": "Max Zoom"
        },
        "min_zoom": {
          "anyOf": [
            {
              "maximum": 23,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Minimum recommended zoom level",
          "title": "Min Zoom"
        },
        "prominence": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Feature significance/importance",
          "title": "Prominence"
        },
        "sort_key": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Drawing order (lower = on top)",
          "title": "Sort Key"
        }
      },
      "title": "CartographyContainer",
      "type": "object"
    }
  },
  "description": "Address feature model.",
  "properties": {
    "geometry": {
      "additionalProperties": true,
      "description": "GeoJSON geometry (Point)",
      "properties": {
        "type": {
          "enum": [
            "Point"
          ],
          "type": "string"
        }
      },
      "title": "Geometry",
      "type": "object"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "properties": {
      "$ref": "#/$defs/AddressProperties",
      "description": "Address feature properties"
    },
    "type": {
      "const": "Feature",
      "default": "Feature",
      "description": "GeoJSON type",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "id",
    "geometry",
    "properties"
  ],
  "title": "AddressFeature",
  "type": "object"
}