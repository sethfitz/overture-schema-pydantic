{
  "$defs": {
    "CartographyContainer": {
      "additionalProperties": false,
      "description": "Cartographic hints for optimal map display.",
      "properties": {
        "max_zoom": {
          "default": null,
          "description": "Maximum recommended zoom level",
          "maximum": 23,
          "minimum": 0,
          "title": "Max Zoom",
          "type": "integer"
        },
        "min_zoom": {
          "default": null,
          "description": "Minimum recommended zoom level",
          "maximum": 23,
          "minimum": 0,
          "title": "Min Zoom",
          "type": "integer"
        },
        "prominence": {
          "default": null,
          "description": "Feature significance/importance",
          "maximum": 100,
          "minimum": 1,
          "title": "Prominence",
          "type": "integer"
        },
        "sort_key": {
          "default": null,
          "description": "Drawing order (lower = on top)",
          "title": "Sort Key",
          "type": "integer"
        }
      },
      "title": "CartographyContainer",
      "type": "object"
    },
    "SourceItem": {
      "additionalProperties": false,
      "description": "Source information for a specific property.",
      "properties": {
        "between": {
          "default": null,
          "description": "Linear referencing range",
          "items": {
            "maximum": 1.0,
            "minimum": 0.0,
            "type": "number"
          },
          "maxItems": 2,
          "minItems": 2,
          "title": "Between",
          "type": "array"
        },
        "confidence": {
          "default": null,
          "description": "Confidence value for ML-derived data",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id",
          "type": "string"
        },
        "update_time": {
          "default": null,
          "description": "When this property was last updated",
          "format": "date-time",
          "title": "Update Time",
          "type": "string"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "SourceItem",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Bathymetry feature model.",
  "patternProperties": {
    "^ext_.*$": {
      "description": "Additional top-level properties must be prefixed with `ext_`."
    }
  },
  "properties": {
    "geometry": {
      "description": "Geometry (Polygon or MultiPolygon)",
      "oneOf": [
        {
          "properties": {
            "bbox": {
              "items": {
                "type": "number"
              },
              "minItems": 4,
              "type": "array"
            },
            "coordinates": {
              "items": {
                "items": {
                  "items": {
                    "items": {
                      "type": "number"
                    },
                    "minItems": 2,
                    "type": "array"
                  },
                  "minItems": 4,
                  "type": "array"
                },
                "minItems": 1,
                "type": "array"
              },
              "minItems": 1,
              "type": "array"
            },
            "type": {
              "const": "MultiPolygon",
              "type": "string"
            }
          },
          "required": [
            "type",
            "coordinates"
          ],
          "type": "object"
        },
        {
          "properties": {
            "bbox": {
              "items": {
                "type": "number"
              },
              "minItems": 4,
              "type": "array"
            },
            "coordinates": {
              "items": {
                "items": {
                  "items": {
                    "type": "number"
                  },
                  "minItems": 2,
                  "type": "array"
                },
                "minItems": 4,
                "type": "array"
              },
              "minItems": 1,
              "type": "array"
            },
            "type": {
              "const": "Polygon",
              "type": "string"
            }
          },
          "required": [
            "type",
            "coordinates"
          ],
          "type": "object"
        }
      ],
      "title": "Geometry"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "properties": {
      "additionalProperties": false,
      "patternProperties": {
        "^ext_.*$": {
          "description": "Additional top-level properties must be prefixed with `ext_`."
        }
      },
      "properties": {
        "cartography": {
          "$ref": "#/$defs/CartographyContainer",
          "default": null,
          "description": "Cartographic display hints"
        },
        "depth": {
          "description": "Water depth in meters (>= 0)",
          "minimum": 0,
          "title": "Depth",
          "type": "integer"
        },
        "sources": {
          "default": null,
          "description": "Source information",
          "items": {
            "$ref": "#/$defs/SourceItem"
          },
          "title": "Sources",
          "type": "array"
        },
        "theme": {
          "const": "base",
          "description": "Feature theme",
          "title": "Theme",
          "type": "string"
        },
        "type": {
          "const": "bathymetry",
          "description": "Feature type",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "description": "Feature version number",
          "minimum": 0,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "theme",
        "type",
        "version",
        "depth"
      ],
      "type": "object",
      "unevaluatedProperties": false
    },
    "type": {
      "const": "Feature",
      "type": "string"
    }
  },
  "required": [
    "id",
    "geometry",
    "properties",
    "type"
  ],
  "title": "Bathymetry",
  "type": "object"
}