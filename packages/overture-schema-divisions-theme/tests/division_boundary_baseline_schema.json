{
  "$defs": {
    "AreaBoundaryClass": {
      "description": "Area and boundary class designations.",
      "enum": [
        "land",
        "maritime"
      ],
      "title": "AreaBoundaryClass",
      "type": "string"
    },
    "PerspectiveMode": {
      "description": "Perspective mode for disputed names.",
      "enum": [
        "accepted_by",
        "disputed_by"
      ],
      "title": "PerspectiveMode",
      "type": "string"
    },
    "Perspectives": {
      "additionalProperties": false,
      "description": "Political perspectives container.",
      "properties": {
        "countries": {
          "description": "ISO 3166-1 alpha-2 country codes",
          "items": {
            "description": "ISO 3166-1 alpha-2 country code",
            "maxLength": 2,
            "minLength": 2,
            "pattern": "^[A-Z]{2}$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Countries",
          "type": "array",
          "uniqueItems": true
        },
        "mode": {
          "$ref": "#/$defs/PerspectiveMode",
          "description": "Perspective mode"
        }
      },
      "required": [
        "mode",
        "countries"
      ],
      "title": "Perspectives",
      "type": "object"
    },
    "PlaceType": {
      "description": "Administrative hierarchy levels for divisions.",
      "enum": [
        "country",
        "dependency",
        "macroregion",
        "region",
        "macrocounty",
        "county",
        "localadmin",
        "locality",
        "borough",
        "macrohood",
        "neighborhood",
        "microhood"
      ],
      "title": "PlaceType",
      "type": "string"
    },
    "SourceItem": {
      "additionalProperties": false,
      "description": "Source information for a specific property.",
      "properties": {
        "between": {
          "default": null,
          "description": "Linear referencing range",
          "items": {
            "maximum": 1.0,
            "minimum": 0.0,
            "type": "number"
          },
          "maxItems": 2,
          "minItems": 2,
          "title": "Between",
          "type": "array"
        },
        "confidence": {
          "default": null,
          "description": "Confidence value for ML-derived data",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id",
          "type": "string"
        },
        "update_time": {
          "default": null,
          "description": "When this property was last updated",
          "format": "date-time",
          "title": "Update Time",
          "type": "string"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "SourceItem",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Division boundary feature model.",
  "patternProperties": {
    "^ext_.*$": {
      "description": "Additional top-level properties must be prefixed with `ext_`."
    }
  },
  "properties": {
    "geometry": {
      "description": "Geometry (LineString or MultiLineString)",
      "oneOf": [
        {
          "properties": {
            "bbox": {
              "items": {
                "type": "number"
              },
              "minItems": 4,
              "type": "array"
            },
            "coordinates": {
              "items": {
                "items": {
                  "type": "number"
                },
                "minItems": 2,
                "type": "array"
              },
              "minItems": 2,
              "type": "array"
            },
            "type": {
              "const": "LineString",
              "type": "string"
            }
          },
          "required": [
            "type",
            "coordinates"
          ],
          "type": "object"
        },
        {
          "properties": {
            "bbox": {
              "items": {
                "type": "number"
              },
              "minItems": 4,
              "type": "array"
            },
            "coordinates": {
              "items": {
                "items": {
                  "items": {
                    "type": "number"
                  },
                  "minItems": 2,
                  "type": "array"
                },
                "minItems": 2,
                "type": "array"
              },
              "minItems": 1,
              "type": "array"
            },
            "type": {
              "const": "MultiLineString",
              "type": "string"
            }
          },
          "required": [
            "type",
            "coordinates"
          ],
          "type": "object"
        }
      ],
      "title": "Geometry"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "properties": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "subtype": {
                "not": {
                  "const": "country"
                }
              }
            }
          },
          "then": {
            "required": [
              "country"
            ]
          }
        }
      ],
      "oneOf": [
        {
          "properties": {
            "is_land": {
              "const": true
            }
          }
        },
        {
          "properties": {
            "is_territorial": {
              "const": true
            }
          }
        }
      ],
      "patternProperties": {
        "^ext_.*$": {
          "description": "Additional top-level properties must be prefixed with `ext_`."
        }
      },
      "properties": {
        "class": {
          "$ref": "#/$defs/AreaBoundaryClass",
          "description": "Boundary class (land/maritime)"
        },
        "country": {
          "default": null,
          "description": "ISO 3166-1 alpha-2 country code (not for country boundaries)",
          "maxLength": 2,
          "minLength": 2,
          "pattern": "^[A-Z]{2}$",
          "title": "Country",
          "type": "string"
        },
        "division_ids": {
          "description": "Two division IDs (left/right)",
          "items": {
            "type": "string"
          },
          "maxItems": 2,
          "minItems": 2,
          "title": "Division Ids",
          "type": "array",
          "uniqueItems": true
        },
        "is_disputed": {
          "default": null,
          "description": "Boundary is disputed",
          "title": "Is Disputed",
          "type": "boolean"
        },
        "is_land": {
          "default": null,
          "description": "Land boundary designation",
          "title": "Is Land",
          "type": "boolean"
        },
        "is_territorial": {
          "default": null,
          "description": "Territorial boundary designation",
          "title": "Is Territorial",
          "type": "boolean"
        },
        "perspectives": {
          "$ref": "#/$defs/Perspectives",
          "default": null,
          "description": "Political perspectives"
        },
        "region": {
          "default": null,
          "description": "ISO 3166-2 region code",
          "maxLength": 6,
          "minLength": 4,
          "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$",
          "title": "Region",
          "type": "string"
        },
        "sources": {
          "default": null,
          "description": "Source information",
          "items": {
            "$ref": "#/$defs/SourceItem"
          },
          "title": "Sources",
          "type": "array"
        },
        "subtype": {
          "$ref": "#/$defs/PlaceType",
          "description": "Administrative level"
        },
        "theme": {
          "const": "divisions",
          "description": "Feature theme",
          "title": "Theme",
          "type": "string"
        },
        "type": {
          "const": "division_boundary",
          "description": "Feature type",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "description": "Feature version number",
          "minimum": 0,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "theme",
        "type",
        "version",
        "subtype",
        "class",
        "division_ids"
      ],
      "type": "object",
      "unevaluatedProperties": false
    },
    "type": {
      "const": "Feature",
      "type": "string"
    }
  },
  "required": [
    "id",
    "geometry",
    "properties",
    "type"
  ],
  "title": "DivisionBoundary",
  "type": "object"
}