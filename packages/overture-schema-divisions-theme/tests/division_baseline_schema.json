{
  "$defs": {
    "CapitalOfDivisionItem": {
      "additionalProperties": false,
      "description": "Division that has this division as capital.",
      "properties": {
        "division_id": {
          "description": "Division identifier",
          "title": "Division Id",
          "type": "string"
        },
        "subtype": {
          "$ref": "#/$defs/PlaceType",
          "description": "Administrative level"
        }
      },
      "required": [
        "division_id",
        "subtype"
      ],
      "title": "CapitalOfDivisionItem",
      "type": "object"
    },
    "CartographyContainer": {
      "additionalProperties": false,
      "description": "Cartographic hints for optimal map display.",
      "properties": {
        "max_zoom": {
          "default": null,
          "description": "Maximum recommended zoom level",
          "maximum": 23,
          "minimum": 0,
          "title": "Max Zoom",
          "type": "integer"
        },
        "min_zoom": {
          "default": null,
          "description": "Minimum recommended zoom level",
          "maximum": 23,
          "minimum": 0,
          "title": "Min Zoom",
          "type": "integer"
        },
        "prominence": {
          "default": null,
          "description": "Feature significance/importance",
          "maximum": 100,
          "minimum": 1,
          "title": "Prominence",
          "type": "integer"
        },
        "sort_key": {
          "default": null,
          "description": "Drawing order (lower = on top)",
          "title": "Sort Key",
          "type": "integer"
        }
      },
      "title": "CartographyContainer",
      "type": "object"
    },
    "DivisionClass": {
      "description": "Division-specific class designations.",
      "enum": [
        "megacity",
        "city",
        "town",
        "village",
        "hamlet"
      ],
      "title": "DivisionClass",
      "type": "string"
    },
    "HierarchyItem": {
      "additionalProperties": false,
      "description": "Single item in administrative hierarchy.",
      "properties": {
        "division_id": {
          "description": "Division identifier",
          "title": "Division Id",
          "type": "string"
        },
        "name": {
          "description": "Division name",
          "title": "Name",
          "type": "string"
        },
        "subtype": {
          "$ref": "#/$defs/PlaceType",
          "description": "Administrative level"
        }
      },
      "required": [
        "division_id",
        "subtype",
        "name"
      ],
      "title": "HierarchyItem",
      "type": "object"
    },
    "NameRule": {
      "additionalProperties": false,
      "description": "Name rule with variant and language specification.",
      "properties": {
        "between": {
          "default": null,
          "description": "Linear referencing range",
          "items": {
            "maximum": 1.0,
            "minimum": 0.0,
            "type": "number"
          },
          "maxItems": 2,
          "minItems": 2,
          "title": "Between",
          "type": "array"
        },
        "language": {
          "default": null,
          "description": "IETF BCP-47 language tag",
          "pattern": "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$",
          "title": "Language",
          "type": "string"
        },
        "perspectives": {
          "$ref": "#/$defs/Perspectives",
          "default": null,
          "description": "Political perspectives"
        },
        "side": {
          "default": null,
          "description": "Side specification",
          "enum": [
            "left",
            "right"
          ],
          "title": "Side",
          "type": "string"
        },
        "value": {
          "description": "Name value",
          "minLength": 1,
          "pattern": "^(\\S.*)?\\S$",
          "title": "Value",
          "type": "string"
        },
        "variant": {
          "$ref": "#/$defs/NameVariant",
          "description": "Name variant type"
        }
      },
      "required": [
        "value",
        "variant"
      ],
      "title": "NameRule",
      "type": "object"
    },
    "NameVariant": {
      "description": "Name variant types.",
      "enum": [
        "common",
        "official",
        "alternate",
        "short"
      ],
      "title": "NameVariant",
      "type": "string"
    },
    "NamesContainer": {
      "additionalProperties": false,
      "description": "Multilingual names container.",
      "properties": {
        "common": {
          "additionalProperties": false,
          "default": null,
          "description": "Common names by language",
          "patternProperties": {
            "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$": {
              "description": "String with no leading/trailing whitespace",
              "pattern": "^(\\S.*)?\\S$",
              "type": "string"
            }
          },
          "propertyNames": {
            "description": "IETF BCP-47 language tag"
          },
          "title": "Common",
          "type": "object"
        },
        "primary": {
          "description": "Primary name",
          "minLength": 1,
          "pattern": "^(\\S.*)?\\S$",
          "title": "Primary",
          "type": "string"
        },
        "rules": {
          "default": null,
          "description": "Name rules",
          "items": {
            "$ref": "#/$defs/NameRule"
          },
          "title": "Rules",
          "type": "array"
        }
      },
      "required": [
        "primary"
      ],
      "title": "NamesContainer",
      "type": "object"
    },
    "Norms": {
      "additionalProperties": false,
      "description": "Local norms and standards.",
      "properties": {
        "driving_side": {
          "$ref": "#/$defs/Side",
          "default": null,
          "description": "Driving side (inheritable from parent)"
        }
      },
      "title": "Norms",
      "type": "object"
    },
    "PerspectiveMode": {
      "description": "Perspective mode for disputed names.",
      "enum": [
        "accepted_by",
        "disputed_by"
      ],
      "title": "PerspectiveMode",
      "type": "string"
    },
    "Perspectives": {
      "additionalProperties": false,
      "description": "Political perspectives container.",
      "properties": {
        "countries": {
          "description": "ISO 3166-1 alpha-2 country codes",
          "items": {
            "description": "ISO 3166-1 alpha-2 country code",
            "maxLength": 2,
            "minLength": 2,
            "pattern": "^[A-Z]{2}$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Countries",
          "type": "array",
          "uniqueItems": true
        },
        "mode": {
          "$ref": "#/$defs/PerspectiveMode",
          "description": "Perspective mode"
        }
      },
      "required": [
        "mode",
        "countries"
      ],
      "title": "Perspectives",
      "type": "object"
    },
    "PlaceType": {
      "description": "Administrative hierarchy levels for divisions.",
      "enum": [
        "country",
        "dependency",
        "macroregion",
        "region",
        "macrocounty",
        "county",
        "localadmin",
        "locality",
        "borough",
        "macrohood",
        "neighborhood",
        "microhood"
      ],
      "title": "PlaceType",
      "type": "string"
    },
    "Side": {
      "description": "Driving side for norms.",
      "enum": [
        "left",
        "right"
      ],
      "title": "Side",
      "type": "string"
    },
    "SourceItem": {
      "additionalProperties": false,
      "description": "Source information for a specific property.",
      "properties": {
        "between": {
          "default": null,
          "description": "Linear referencing range",
          "items": {
            "maximum": 1.0,
            "minimum": 0.0,
            "type": "number"
          },
          "maxItems": 2,
          "minItems": 2,
          "title": "Between",
          "type": "array"
        },
        "confidence": {
          "default": null,
          "description": "Confidence value for ML-derived data",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id",
          "type": "string"
        },
        "update_time": {
          "default": null,
          "description": "When this property was last updated",
          "format": "date-time",
          "title": "Update Time",
          "type": "string"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "SourceItem",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Division feature model.",
  "patternProperties": {
    "^ext_.*$": {
      "description": "Additional top-level properties must be prefixed with `ext_`."
    }
  },
  "properties": {
    "geometry": {
      "description": "Point geometry for division location",
      "properties": {
        "bbox": {
          "items": {
            "type": "number"
          },
          "minItems": 4,
          "type": "array"
        },
        "coordinates": {
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "type": "array"
        },
        "type": {
          "const": "Point",
          "type": "string"
        }
      },
      "required": [
        "type",
        "coordinates"
      ],
      "title": "Geometry",
      "type": "object"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "properties": {
      "additionalProperties": false,
      "allOf": [
        {
          "else": {
            "required": [
              "parent_division_id"
            ]
          },
          "if": {
            "properties": {
              "subtype": {
                "const": "country"
              }
            }
          },
          "then": {
            "not": {
              "required": [
                "parent_division_id"
              ]
            }
          }
        }
      ],
      "patternProperties": {
        "^ext_.*$": {
          "description": "Additional top-level properties must be prefixed with `ext_`."
        }
      },
      "properties": {
        "capital_division_ids": {
          "default": null,
          "description": "Capital division identifiers",
          "items": {
            "description": "String without whitespace characters",
            "pattern": "^\\S+$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Capital Division Ids",
          "type": "array",
          "uniqueItems": true
        },
        "capital_of_divisions": {
          "default": null,
          "description": "Divisions this is capital of",
          "items": {
            "$ref": "#/$defs/CapitalOfDivisionItem"
          },
          "minItems": 1,
          "title": "Capital Of Divisions",
          "type": "array",
          "uniqueItems": true
        },
        "cartography": {
          "$ref": "#/$defs/CartographyContainer",
          "default": null,
          "description": "Cartographic display hints"
        },
        "class": {
          "$ref": "#/$defs/DivisionClass",
          "default": null,
          "description": "Division class designation"
        },
        "country": {
          "description": "ISO 3166-1 alpha-2 country code",
          "maxLength": 2,
          "minLength": 2,
          "pattern": "^[A-Z]{2}$",
          "title": "Country",
          "type": "string"
        },
        "hierarchies": {
          "description": "Administrative hierarchy chains",
          "items": {
            "items": {
              "$ref": "#/$defs/HierarchyItem"
            },
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "minItems": 1,
          "title": "Hierarchies",
          "type": "array"
        },
        "local_type": {
          "additionalProperties": {
            "type": "string"
          },
          "default": null,
          "description": "Localized subtype name",
          "title": "Local Type",
          "type": "object"
        },
        "names": {
          "$ref": "#/$defs/NamesContainer",
          "description": "Multilingual names"
        },
        "norms": {
          "$ref": "#/$defs/Norms",
          "default": null,
          "description": "Local norms"
        },
        "parent_division_id": {
          "default": null,
          "description": "Parent division identifier",
          "minLength": 1,
          "pattern": "^\\S+$",
          "title": "Parent Division Id",
          "type": "string"
        },
        "perspectives": {
          "$ref": "#/$defs/Perspectives",
          "default": null,
          "description": "Political perspectives"
        },
        "population": {
          "default": null,
          "description": "Population count",
          "minimum": 0,
          "title": "Population",
          "type": "integer"
        },
        "prominence": {
          "default": null,
          "description": "Prominence score (0.0-1.0)",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Prominence",
          "type": "number"
        },
        "region": {
          "default": null,
          "description": "ISO 3166-2 region code",
          "maxLength": 6,
          "minLength": 4,
          "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$",
          "title": "Region",
          "type": "string"
        },
        "sources": {
          "default": null,
          "description": "Source information",
          "items": {
            "$ref": "#/$defs/SourceItem"
          },
          "title": "Sources",
          "type": "array"
        },
        "subtype": {
          "$ref": "#/$defs/PlaceType",
          "description": "Administrative level"
        },
        "theme": {
          "const": "divisions",
          "description": "Feature theme",
          "title": "Theme",
          "type": "string"
        },
        "type": {
          "const": "division",
          "description": "Feature type",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "description": "Feature version number",
          "minimum": 0,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "theme",
        "type",
        "version",
        "country",
        "hierarchies",
        "names",
        "subtype"
      ],
      "type": "object",
      "unevaluatedProperties": false
    },
    "type": {
      "const": "Feature",
      "type": "string"
    }
  },
  "required": [
    "id",
    "geometry",
    "properties",
    "type"
  ],
  "title": "Division",
  "type": "object"
}