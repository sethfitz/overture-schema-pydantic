{
  "$defs": {
    "AdvancedSourceItem": {
      "description": "Advanced source information with linear referencing support.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Confidence value for ML-derived data",
          "title": "Confidence"
        },
        "dataset": {
          "description": "Source dataset identifier",
          "title": "Dataset",
          "type": "string"
        },
        "property": {
          "description": "JSON Pointer to the property",
          "title": "Property",
          "type": "string"
        },
        "record_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific record within dataset",
          "title": "Record Id"
        },
        "update_time": {
          "anyOf": [
            {
              "description": "ISO 8601 datetime",
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "When this property was last updated (ISO 8601)",
          "title": "Update Time"
        }
      },
      "required": [
        "property",
        "dataset"
      ],
      "title": "AdvancedSourceItem",
      "type": "object"
    },
    "CartographyContainer": {
      "description": "Cartographic hints for optimal map display.",
      "properties": {
        "max_zoom": {
          "anyOf": [
            {
              "maximum": 23,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum recommended zoom level",
          "title": "Max Zoom"
        },
        "min_zoom": {
          "anyOf": [
            {
              "maximum": 23,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Minimum recommended zoom level",
          "title": "Min Zoom"
        },
        "prominence": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Feature significance/importance",
          "title": "Prominence"
        },
        "sort_key": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Drawing order (lower = on top)",
          "title": "Sort Key"
        }
      },
      "title": "CartographyContainer",
      "type": "object"
    },
    "LandClass": {
      "description": "Land class classification.",
      "enum": [
        "archipelago",
        "bare_rock",
        "beach",
        "cave_entrance",
        "cliff",
        "desert",
        "dune",
        "fell",
        "forest",
        "glacier",
        "grass",
        "grassland",
        "heath",
        "hill",
        "island",
        "islet",
        "land",
        "meadow",
        "meteor_crater",
        "mountain_range",
        "peak",
        "peninsula",
        "plateau",
        "reef",
        "ridge",
        "rock",
        "saddle",
        "sand",
        "scree",
        "scrub",
        "shingle",
        "shrub",
        "shrubbery",
        "stone",
        "tree",
        "tree_row",
        "tundra",
        "valley",
        "volcanic_caldera_rim",
        "volcano",
        "wetland",
        "wood"
      ],
      "title": "LandClass",
      "type": "string"
    },
    "LandProperties": {
      "additionalProperties": true,
      "description": "Properties specific to land features.",
      "properties": {
        "cartography": {
          "anyOf": [
            {
              "$ref": "#/$defs/CartographyContainer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Cartographic display hints"
        },
        "class": {
          "$ref": "#/$defs/LandClass",
          "description": "Land class"
        },
        "elevation": {
          "anyOf": [
            {
              "maximum": 9000,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Elevation above sea level in meters",
          "title": "Elevation"
        },
        "names": {
          "anyOf": [
            {
              "$ref": "#/$defs/NamesContainer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Multilingual names"
        },
        "source_tags": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Source tags from data providers",
          "title": "Source Tags"
        },
        "sources": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/AdvancedSourceItem"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Advanced source information",
          "title": "Sources"
        },
        "subtype": {
          "$ref": "#/$defs/LandSubtype",
          "description": "Land subtype"
        },
        "surface": {
          "anyOf": [
            {
              "$ref": "#/$defs/SurfaceMaterial"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Surface material"
        },
        "theme": {
          "description": "Top-level Overture theme",
          "title": "Theme",
          "type": "string"
        },
        "type": {
          "description": "Specific feature type within theme",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "description": "Feature version number",
          "minimum": 0,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "theme",
        "type",
        "version",
        "subtype",
        "class"
      ],
      "title": "LandProperties",
      "type": "object"
    },
    "LandSubtype": {
      "description": "Land subtype classification.",
      "enum": [
        "crater",
        "desert",
        "forest",
        "glacier",
        "grass",
        "land",
        "physical",
        "reef",
        "rock",
        "sand",
        "shrub",
        "tree",
        "wetland"
      ],
      "title": "LandSubtype",
      "type": "string"
    },
    "NamePerspectives": {
      "description": "Political perspectives for names.",
      "properties": {
        "countries": {
          "description": "ISO 3166-1 alpha-2 country codes",
          "items": {
            "description": "ISO 3166-1 alpha-2 country code",
            "pattern": "^[A-Z]{2}$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Countries",
          "type": "array"
        },
        "mode": {
          "$ref": "#/$defs/PerspectiveMode",
          "description": "Perspective mode"
        }
      },
      "required": [
        "mode",
        "countries"
      ],
      "title": "NamePerspectives",
      "type": "object"
    },
    "NameRule": {
      "description": "Name rule with variant and language specification.",
      "properties": {
        "between": {
          "anyOf": [
            {
              "description": "Linear reference range [start, end] where 0.0 <= start < end <= 1.0",
              "items": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Linear referencing range",
          "title": "Between"
        },
        "language": {
          "anyOf": [
            {
              "description": "IETF BCP-47 language tag",
              "pattern": "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "IETF BCP-47 language tag",
          "title": "Language"
        },
        "perspectives": {
          "anyOf": [
            {
              "$ref": "#/$defs/NamePerspectives"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Political perspectives"
        },
        "side": {
          "anyOf": [
            {
              "enum": [
                "left",
                "right"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Side specification",
          "title": "Side"
        },
        "value": {
          "description": "Name value",
          "minLength": 1,
          "title": "Value",
          "type": "string"
        },
        "variant": {
          "$ref": "#/$defs/NameVariant",
          "description": "Name variant type"
        }
      },
      "required": [
        "variant",
        "value"
      ],
      "title": "NameRule",
      "type": "object"
    },
    "NameVariant": {
      "description": "Name variant types.",
      "enum": [
        "common",
        "official",
        "alternate",
        "short"
      ],
      "title": "NameVariant",
      "type": "string"
    },
    "NamesContainer": {
      "additionalProperties": true,
      "description": "Multilingual names container.",
      "properties": {
        "common": {
          "anyOf": [
            {
              "patternProperties": {
                "^[a-z]{2,3}(-[A-Za-z]{2,8})*(-[0-9][A-Za-z0-9]{3})*$": {
                  "type": "string"
                }
              },
              "propertyNames": {
                "description": "IETF BCP-47 language tag"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Common names by language",
          "title": "Common"
        },
        "primary": {
          "description": "Primary name",
          "minLength": 1,
          "title": "Primary",
          "type": "string"
        },
        "rules": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/NameRule"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Name rules",
          "title": "Rules"
        }
      },
      "required": [
        "primary"
      ],
      "title": "NamesContainer",
      "type": "object"
    },
    "PerspectiveMode": {
      "description": "Perspective mode for disputed names.",
      "enum": [
        "accepted_by",
        "disputed_by"
      ],
      "title": "PerspectiveMode",
      "type": "string"
    },
    "SurfaceMaterial": {
      "description": "Surface material enum used by infrastructure and land features.",
      "enum": [
        "asphalt",
        "cobblestone",
        "compacted",
        "concrete",
        "concrete_plates",
        "dirt",
        "earth",
        "fine_gravel",
        "grass",
        "gravel",
        "ground",
        "paved",
        "paving_stones",
        "pebblestone",
        "recreation_grass",
        "recreation_paved",
        "recreation_sand",
        "rubber",
        "sand",
        "sett",
        "tartan",
        "unpaved",
        "wood",
        "woodchips"
      ],
      "title": "SurfaceMaterial",
      "type": "string"
    }
  },
  "description": "Land feature model.",
  "properties": {
    "geometry": {
      "additionalProperties": true,
      "description": "GeoJSON geometry",
      "title": "Geometry",
      "type": "object"
    },
    "id": {
      "description": "Feature identifier",
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "properties": {
      "$ref": "#/$defs/LandProperties",
      "description": "Land feature properties"
    },
    "type": {
      "default": "Feature",
      "description": "GeoJSON type",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "id",
    "geometry",
    "properties"
  ],
  "title": "LandFeature",
  "type": "object"
}